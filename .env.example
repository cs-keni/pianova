PIANOVA_APP_NAME=Pianova
PIANOVA_ENVIRONMENT=development
PIANOVA_DATABASE_URL=sqlite:///./workspace/pianova.db
PIANOVA_WORKSPACE_DIR=./workspace
PIANOVA_FFMPEG_PATH=
PIANOVA_FFPROBE_PATH=
PIANOVA_MUSESCORE_PATH=
PIANOVA_MAX_UPLOAD_MB=250
PIANOVA_LOG_LEVEL=INFO
PIANOVA_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
PIANOVA_DEPENDENCY_PROBE_TIMEOUT_SECONDS=3
