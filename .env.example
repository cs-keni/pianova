PIANOVA_MEDIA_NORMALIZATION_TIMEOUT_SECONDS=300
PIANOVA_NORMALIZED_SAMPLE_RATE=22050
PIANOVA_NORMALIZED_CHANNELS=1
PIANOVA_TRANSCRIPTION_PYTHON_PATH=
PIANOVA_TRANSCRIPTION_PROBE_TIMEOUT_SECONDS=30
PIANOVA_TRANSCRIPTION_TIMEOUT_SECONDS=1800
PIANOVA_TRANSCRIPTION_MINIMUM_DURATION_SECONDS=0.05
PIANOVA_TRANSCRIPTION_ONSET_THRESHOLD=0.5
PIANOVA_TRANSCRIPTION_FRAME_THRESHOLD=0.3
